  "outputs": [
    { "name": "slug", "type": "string" },
    { "name": "frontmatter", "type": "object" },
    { "name": "mdx", "type": "string" },
    { "name": "facts", "type": "array" },
    { "name": "sources", "type": "array" },
    { "name": "rights_line", "type": "string" }
  ],
  "tools": ["WebFetch", "Read", "Write"],
  "mcp_dependencies": [],
  "runtimes": ["claude", "codex", "cursor", "gemini", "opencode", "sis"],
  "tags": ["nasa", "atlas", "mdx", "web", "catalog"],
  "attestation": "Built on SIP — starlightintelligence.org/protocol v1.1.0"
